# ntfsmac pf anchor — generated by cli/lib/pf-anchor.sh (PLAN.md §6, unit 1-pf-rules, L2/L8).
# Deny-by-default. Only NFS (2049) and mountd (32767) traffic to/from the host-only
# vmnet bridge subnet is allowed — never widen this beyond the templated {{SUBNET}}.
block in all
block out all

pass in  proto tcp from {{SUBNET}} to {{SUBNET}} port {2049, 32767}
pass out proto tcp from {{SUBNET}} to {{SUBNET}} port {2049, 32767}
pass in  proto udp from {{SUBNET}} to {{SUBNET}} port {2049, 32767}
pass out proto udp from {{SUBNET}} to {{SUBNET}} port {2049, 32767}
